# Top-most EditorConfig file
root = true

# エンコードと改行コードの設定
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true

# C#のインデント設定
[*.cs]
indent_style = space
indent_size = 4

# @formatter:off

# デフォルトとして、Assets以下のすべてをクリーンアップから除外する
[Assets/**]
resharper_substitution_for_cleanup_profile = * => Skip

# クリーンアップしたい特定のフォルダ（例: Assets/Scripts）だけを対象に戻す
[Assets/Wand/**]
resharper_substitution_for_cleanup_profile = * => default

[Assets/JoyConTest/**]
resharper_substitution_for_cleanup_profile = * => default

[Assets/UnityJoyCon/**]
resharper_substitution_for_cleanup_profile = * => default

# @formatter:on
