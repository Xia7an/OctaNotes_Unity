{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "ca62423790574731b5f8adb734698f57",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "hex (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -918.0,
            "y": -174.0,
            "width": 208.0,
            "height": 302.0
        }
    },
    "m_Slots": [
        {
            "m_Id": "7ed21d496bae4d04a198a2357c32ff2a"
        },
        {
            "m_Id": "e7ca6834f63e45a8b01ed8b55e9799fd"
        },
        {
            "m_Id": "eb64c8edcfdd46f3ac31520f06acc799"
        },
        {
            "m_Id": "1e18f6757f4044bd9116590e33ec54c7"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": true,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "hex",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float2 r = float2(1.0, 1.7320508); // 1.0, sqrt(3)\nfloat2 h = r * 0.5;\n\n// GLSLのmod(x, y) は HLSLでは x - y * floor(x/y) で代用します\nfloat2 gridA = UV * Scale;\nfloat2 a = gridA - r * floor(gridA / r) - h;\n\nfloat2 gridB = UV * Scale + h;\nfloat2 b = gridB - r * floor(gridB / r) - h;\n\nfloat2 f = dot(a, a) < dot(b, b) ? a : b;\n\n// HexDist: 六角形の中心からの距離\nHexDist = max(abs(f.x) * 0.866025 + abs(f.y) * 0.5, abs(f.y)); \n\n// CellID: 各セルの個別ID（中心座標）\nCellID = (UV * Scale - f) / Scale;"
}

